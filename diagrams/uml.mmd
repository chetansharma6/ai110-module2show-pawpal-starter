classDiagram
    %% PawPal+ — daily pet care planning assistant
    %% Keep this file updated so it matches your final implementation.

    class Owner {
        +str name
        +int time_available
        +dict preferences
        +list~Pet~ pets
        +add_pet(pet) None
        +update_preferences(preferences) None
        +get_all_tasks() list~Task~
    }

    class Pet {
        +str name
        +str species
        +int age
        +list~Task~ tasks
        +update_info(name, species, age) None
        +add_task(task) None
        +remove_task(task) None
        +get_tasks() list~Task~
    }

    class Task {
        +str description
        +int duration
        +str frequency
        +str priority
        +bool completed
        +mark_complete() None
        +edit_task(description, duration, frequency, priority) None
    }

    class Scheduler {
        +Owner owner
        +int available_time
        +list~Task~ schedule
        +list~str~ reasoning
        +prioritize_tasks() list~Task~
        +generate_schedule() list~Task~
        +explain_plan() str
    }

    Owner "1" --> "1..*" Pet : owns
    Pet "1" --> "0..*" Task : has
    Scheduler "1" --> "1" Owner : plans for
    Scheduler ..> Task : schedules
